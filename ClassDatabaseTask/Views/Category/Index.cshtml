@{
    ViewData["Title"] = "Index";
}

@if(@TempData["Msg"] != null)
{
    <p class="alert alert-success">@TempData["Msg"]</p>
}

<h1>Index</h1>
<table class="table table-bordered">
    <tr>
        <th>Id</th>
        <th>Name</th>
    </tr>

    @foreach(var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Name</td>
        </tr>
    }
</table>
